{
  "compilerOptions": {
    "experimentalDecorators": true,
    "module": "node16",
    "target": "es2018",
    "lib": ["es2018", "dom"],
    "noImplicitAny": false,
    "moduleResolution": "node16",
    "emitDecoratorMetadata": true,
    "isolatedModules": true,
    "sourceMap": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["**/node_modules/**", "**/__tests__/**"],
  "filesGlob": ["typings.d.ts", "./src/**/*.js", "./src/**/*.ts"]
}
